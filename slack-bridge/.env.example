# Slack tokens — from your Slack app config (api.slack.com/apps).
# - Bot token: OAuth & Permissions → Bot User OAuth Token (xoxb-…)
# - App token: Basic Information → App-Level Tokens, scope `connections:write` (xapp-…)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Supabase session store — enables durable cross-restart session continuity.
# The bridge starts without these but per-thread session resume won't survive
# process restarts (SDK falls back to in-memory + local JSONL).
# Service-role key: Supabase Dashboard → Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Claude Code OAuth token (subscription-backed, not an API key).
# Generate with: `claude setup-token`
# Survives Keychain ACL changes after cask upgrades — recommended over
# relying on the per-user `claude /login` Keychain entry when running as
# a launchd daemon.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Optional
LOG_LEVEL=info
